# ─── 노션 OAuth (노션 my-integrations에서 발급) ───
NOTION_OAUTH_CLIENT_ID=383d872b-594c-81b4-afd4-003777dc33e0
NOTION_OAUTH_CLIENT_SECRET=여기에_클라이언트_시크릿
NOTION_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Supabase (supabase.com 프로젝트에서 발급) ───
SUPABASE_URL=https://여러분프로젝트.supabase.co
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_키

# ─── 보안 키 (직접 생성) ───
# 토큰 암호화 키: 아래 명령으로 생성 → node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=여기에_64자리_hex
# 세션 서명 키: 아래 명령으로 생성 → node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=여기에_아무_긴_랜덤_문자열
